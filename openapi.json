    "/v1/register": {
      "post": {
        "operationId": "post_v1_register",
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "email": {
                    "format": "email",
                    "pattern": "^(?!\\.)(?!.*\\.\\.)([A-Za-z0-9_'+\\-\\.]*)[A-Za-z0-9_+-]@([A-Za-z0-9][A-Za-z0-9\\-]*\\.)+[A-Za-z]{2,}$",
                    "type": "string"
                  },
                  "firstname": {
                    "maxLength": 255,
                    "minLength": 1,
                    "type": "string"
                  },
                  "jobTitle": {
                    "default": "",
                    "maxLength": 255,
                    "type": "string"
                  },
                  "lastname": {
                    "maxLength": 255,
                    "minLength": 1,
                    "type": "string"
                  },
                  "password": {
                    "maxLength": 512,
                    "minLength": 12,
                    "type": "string"
                  }
                },
                "required": [
                  "email",
                  "firstname",
