    "/v1/discrete-references/{effortMode}": {
      "post": {
        "operationId": "post_v1_discrete_references_effortMode",
        "parameters": [
          {
            "in": "path",
            "name": "effortMode",
            "required": true,
            "schema": {
              "enum": [
                "basic",
                "standard",
                "advanced"
              ],
              "type": "string"
            }
          }
        ],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "properties": {
                  "alpha": {
                    "description": "Hybrid search weight (0=keyword, 1=vector).",
                    "type": "number"
                  },
                  "fileExpiresAt": {
                    "anyOf": [
                      {
                        "type": "string"
                      },
                      {
                        "type": "null"
                      }
                    ]
                  },
                  "fileId": {
                    "description": "ID of the file to get references from.",
                    "type": "number"
                  },
                  "limit": {
                    "description": "Max references to return.",
                    "type": "number"
                  },
                  "markupColor": {
                    "description": "Hex color for marked-up output.",
                    "type": "string"
                  },
                  "markupFile": {
                    "description": "Also return a marked-up copy.",
                    "type": "boolean"
                  },
                  "model": {
                    "description": "Model for the standard/advanced reranker.",
                    "type": "string"
                  },
                  "prompt": {
                    "description": "The topic/question to find references for.",
                    "type": "string"
                  }
                },
                "required": [
                  "fileId",
                  "prompt"
                ],
                "type": "object"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "content": {
              "application/json": {
                "schema": {
                  "additionalProperties": {},
                  "properties": {
                    "abstained": {
                      "type": "boolean"
                    },
                    "cached": {
                      "type": "boolean"
                    },
                    "chargedCost": {
                      "type": "number"
                    },
                    "chargedCostBreakdown": {
                      "additionalProperties": {},
                      "properties": {
                        "llm": {
                          "type": "number"
                        },
                        "query": {
                          "type": "number"
                        }
                      },
                      "required": [
                        "query",
                        "llm"
                      ],
                      "type": "object"
                    },
                    "document": {},
                    "newFileId": {
                      "type": "number"
                    },
                    "references": {
                      "items": {
                        "$ref": "#/components/schemas/CanonicalReference"
                      },
                      "type": "array"
                    },
                    "refs": {
                      "additionalProperties": {},
                      "properties": {
                        "parts": {
                          "items": {},
                          "type": "array"
                        }
                      },
                      "required": [
                        "parts"
                      ],
                      "type": "object"
                    },
                    "schemaVersion": {
                      "enum": [
                        "penpoint.ref/1"
                      ],
                      "type": "string"
                    }
                  },
                  "type": "object"
                }
              }
            },
            "description": "Default Response"
          }
        },
        "summary": "Find discrete references in a file for a topic/question.",
        "tags": [
          "discrete-references"
        ]
      }
    },
