{
  "components": {
    "schemas": {
      "CanonicalReference": {
        "additionalProperties": false,
        "description": "A single citation in the penpoint.ref/1 contract.",
        "properties": {
          "confidence": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "description": "Confidence in [0,1] that this is the right span, or null."
          },
          "id": {
            "description": "Stable id for the cited span.",
            "type": "string"
          },
          "locator": {
            "$ref": "#/components/schemas/ReferenceLocator"
          },
          "segment": {
            "description": "The cited text content.",
            "type": "string"
          }
        },
        "required": [
          "id",
          "segment",
          "confidence",
          "locator"
        ],
        "type": "object"
      },
      "CanonicalReferenceInput": {
        "description": "A single citation in the penpoint.ref/1 contract.",
        "properties": {
          "confidence": {
            "anyOf": [
              {
                "type": "number"
              },
              {
                "type": "null"
              }
            ],
            "description": "Confidence in [0,1] that this is the right span, or null."
          },
          "id": {
            "description": "Stable id for the cited span.",
            "type": "string"
          },
          "locator": {
            "$ref": "#/components/schemas/ReferenceLocatorInput"
          },
          "segment": {
            "description": "The cited text content.",
            "type": "string"
          }
        },
        "required": [
          "id",
          "segment",
          "confidence",
          "locator"
        ],
        "type": "object"
      },
      "ReferenceLocator": {
        "anyOf": [
          {
            "additionalProperties": false,
            "description": "Spatial document locator (PDF/image).",
            "properties": {
              "bbox": {
                "anyOf": [
                  {
                    "prefixItems": [
                      {
                        "type": "number"
                      },
                      {
                        "type": "number"
                      },
                      {
                        "type": "number"
                      },
                      {
                        "type": "number"
                      }
                    ],
                    "type": "array"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Fractional [x, y, w, h]."
              },
              "page": {
                "anyOf": [
                  {
                    "maximum": 9007199254740991,
                    "minimum": -9007199254740991,
                    "type": "integer"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "1-indexed page."
              },
              "type": {
                "enum": [
                  "pdf",
                  "image"
                ],
                "type": "string"
              }
            },
            "required": [
              "type",
              "page",
              "bbox"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "description": "Tabular locator.",
            "properties": {
              "row": {
                "anyOf": [
                  {
                    "maximum": 9007199254740991,
                    "minimum": -9007199254740991,
                    "type": "integer"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "1-indexed source row (header = row 1)."
              },
              "type": {
                "const": "tabular",
                "type": "string"
              }
            },
            "required": [
              "type",
              "row"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "description": "Audio time-range locator.",
            "properties": {
              "endTime": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Seconds."
              },
              "startTime": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Seconds."
              },
              "type": {
                "const": "audio",
                "type": "string"
              }
            },
            "required": [
              "type",
              "startTime",
              "endTime"
            ],
            "type": "object"
          },
          {
            "additionalProperties": false,
            "description": "Plain-text / markdown locator.",
            "properties": {
              "position": {
                "anyOf": [
                  {
                    "type": "number"
                  },
                  {
                    "type": "null"
                  }
                ],
                "description": "Vertical position as a fraction (0..1)."
              },
              "type": {
                "const": "text",
                "type": "string"
              }
            },
            "required": [
              "type",
              "position"
            ],
            "type": "object"
          }
        ],
        "description": "Where a reference lives in the source, normalized per modality."
      },
